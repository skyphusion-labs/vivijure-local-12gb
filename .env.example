# vivijure-local-backend config. Copy to `.env` and fill in. NEVER commit your real .env.
#
# R2 (the SHARED vivijure bucket): the backend reads the keyframe by key and writes the finished clip
# by key, so the studio's local-gpu module never moves bytes. This is the ONE credential the backend
# holds. Use a per-function R2 key scoped to this bucket (read keyframes/, write clips/).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vivijure

# Optional shared secret the server checks on every request (Bearer). The studio's local-gpu module
# sends it as LOCAL_BACKEND_TOKEN. Leave EMPTY to run open on a trusted LAN tunnel; set a long random
# value for defense-in-depth on the tunnel origin. Mint with e.g. `openssl rand -hex 32`.
LOCAL_BACKEND_TOKEN=

# Host bind address for the published port. Default 127.0.0.1 (localhost only) so the render server is
# reachable ONLY via your Cloudflare tunnel, never the open LAN. Set 0.0.0.0 only if you know why.
BIND_ADDR=127.0.0.1
